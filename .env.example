# Your OpenRouter API key (get one at https://openrouter.ai/keys)
OPENAI_API_KEY=sk-or-v1-your-key-here

# Optional: override the model used by the agent.
# 'openrouter/owl-alpha' from the original notebook is a placeholder —
# use a real OpenRouter model id, e.g.:
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o
#   meta-llama/llama-3.1-70b-instruct
AGENT_MODEL=anthropic/claude-3.5-sonnet
